# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# DVC manages large artifacts; ignore the cache itself
/.dvc/cache
/.dvc/tmp

# Quarto
/.quarto/
*_files/

# OS / editor
.DS_Store
*.swp

# Large binary artifacts that should not be in Git
*.ckpt
*.pt
*.bin
*.safetensors
*.parquet
*.arrow
*.tar
*.tar.gz
*.zip

# webapp TLS material — never commit private keys
webapp/certs/
# vendored MediaPipe model/wasm — fetched at first service start
webapp/static/vendor/
# web-collected sessions land in the experiment results dir (handled there)

# native app: per-user tuning + auto-downloaded face model
app/tune.json
app/models/

# Hook telemetry — appended by the Stop hook after every turn, so it can
# never stay committed-clean. Durable copy lives in ~/.claude/state.db.
_meta/token_log.ndjson
