[Unit]
Description=hands-free-control gaze collector webapp (HTTPS, LAN + Tailscale, port 8104)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/mnt/projects/research/hands-free-control/webapp
ExecStart=/home/eschmitt/.local/bin/uv run python serve.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
